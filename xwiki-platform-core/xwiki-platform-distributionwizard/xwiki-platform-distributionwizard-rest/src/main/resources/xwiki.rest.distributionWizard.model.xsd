<schema xmlns="http://www.w3.org/2001/XMLSchema" targetNamespace="http://www.xwiki.org/distributionWizard"
  xmlns:distributionWizard="http://www.xwiki.org/distributionWizard" xmlns:xwiki="http://www.xwiki.org"
  elementFormDefault="qualified">

  <!-- Import the xwiki.rest.model.xsd because we reuse the xwiki:LinkCollection and xwiki:Map types. -->
  <import namespace="http://www.xwiki.org"/>

  <!--
  *
  * Types
  *
  -->

  <complexType name="Steps">
    <complexContent>
      <extension base="xwiki:LinkCollection">
        <sequence>
          <element name="step" type="distributionWizard:Step" minOccurs="0" maxOccurs="unbounded"></element>
        </sequence>
      </extension>
    </complexContent>
  </complexType>

  <complexType name="Step">
    <complexContent>
      <extension base="xwiki:LinkCollection">
        <sequence>
          <element name="id" type="string"></element>
          <element name="title" type="string"></element>
          <element name="index" type="int"></element>
          <element name="optional" type="boolean"></element>
          <element name="hidden" type="boolean"></element>
          <element name="done" type="boolean"></element>
          <element name="html" type="string"></element>
          <element name="uiComponent" type="distributionWizard:UIComponent"></element>
        </sequence>
      </extension>
    </complexContent>
  </complexType>

  <complexType name="UIComponent">
    <complexContent>
      <extension base="xwiki:LinkCollection">
        <attribute name="module" type="string"></attribute>
        <attribute name="component" type="string"></attribute>
      </extension>
    </complexContent>
  </complexType>

  <!--
  *
  * Elements
  *
  -->

  <element name="steps" type="distributionWizard:Steps"></element>

  <element name="step" type="distributionWizard:Step"></element>
</schema>
## Following was taken back from headerhtml.vm; not sure if we shouldn't have a common template for this..
<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml" lang="$xcontext.locale.toLanguageTag()" xml:lang="$xcontext.locale.toLanguageTag()">
<head>
    ## ---------------------------------------------------------------------------------------------------------------
    ## Ensure that the Content-Type meta directive is the first one in the header.
    ## See http://www.w3.org/International/tutorials/tutorial-char-enc/
    ## ---------------------------------------------------------------------------------------------------------------
    <meta http-equiv="Content-Type" content="text/html; charset=$xwiki.encoding" />
    ## ---------------------------------------------------------------------------------------------------------------
    ## Enable Responsiveness for phones
    <meta name="viewport" content="width=device-width, initial-scale=1" />
#template('meta.vm')
<!-- com.xpn.xwiki.plugin.skinx.LinkExtensionPlugin -->
#template("stylesheets.vm")
#template("javascript.vm")
</head>
<body>
    <script type="module">
        import "xwiki-platform-distributionwizard-webjar"
    </script>
    <div id="distributionWizard">
    </div>
</body>
</html>
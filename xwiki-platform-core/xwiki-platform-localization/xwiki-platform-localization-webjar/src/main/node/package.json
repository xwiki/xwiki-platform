  "devDependencies": {
    "@types/node": "catalog:",
    "@types/requirejs": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@xwiki/platform-tool-eslintconfig": "workspace:*",
    "eslint": "catalog:",
    "npm-run-all": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue-i18n": "catalog:",
    "vue-tsc": "catalog:"
  }
}

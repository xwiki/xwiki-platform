<xwikidoc version="1.7" reference="ExtensionCode.ImportProject" locale="">
  <web>ExtensionCode</web>
  <name>ImportProject</name>
  <language/>
  <defaultLanguage/>
  <translation>0</translation>
  <creator>xwiki:XWiki.Admin</creator>
  <parent>WebHome</parent>
  <author>xwiki:XWiki.Admin</author>
  <contentAuthor>xwiki:XWiki.Admin</contentAuthor>
  <version>1.1</version>
  <title>Import a Project</title>
  <comment/>
  <minorEdit>false</minorEdit>
  <syntaxId>xwiki/2.1</syntaxId>
  <hidden>true</hidden>
  <content>{{include reference="ExtensionCode.RepositoryCode"/}}

Import a project coming from a another repository. It's generally used to add complete documentation or search capability for a project in a repository not supporting it.

If a project already exist with the provided id in the wiki, it will be updated.

Example of project id: ##org.xwiki.contrib.latex:latex##

{{velocity}}
#if ($request.importProject == 'true')
  #set($projectDocumentReference = $repositoryManager.importProject($request.projectId, $request.repositoryId))
  #if (!$projectDocumentReference)
    {{error}}Failed to import project: #printThrowable($repositoryManager.lastError){{/error}}
  #else
    {{success}}Redirect to $response.sendRedirect($xwiki.getURL($projectDocumentReference)){{/success}}
  #end
#else
  {{html}}
    #if ($isGuest)
      You need first to &lt;a href="${escapetool.xml($xwiki.getURL("Main.WebHome", "login", "xredirect=$doc.externalURL"))}"&gt;log in&lt;/a&gt; or &lt;a href="${escapetool.xml($xwiki.getURL("xwiki:Main.WebHome", "register", "xredirect=$doc.externalURL"))}"&gt;register&lt;/a&gt;.
    #else
    &lt;form action="$doc.getURL()" id="importextension"&gt;
      &lt;input type="hidden" name="parent" value="Extension.WebHome" /&gt;
      &lt;input type="hidden" name="template" value="ExtensionCode.ProjectTemplate" /&gt;
      &lt;input type="hidden" name="importExtension" value="true" /&gt;
      &lt;input type="text" name="projectId" placeholder="project id..."  size="25" id="importProjectIdInput"/&gt;
      &lt;select name="repositoryId" id="importRepositoryIdInput"&gt;
        #foreach($repository in $extensionManager.repositories)
          #if ($repository.descriptor.type != 'xwiki')
            &lt;option value="$escapetool.xml($repository.descriptor.id)"&gt;$escapetool.html($repository.descriptor.id)&lt;/option&gt;
          #end
        #end
      &lt;/select&gt;
      &lt;span class="buttonwrapper"&gt;
        &lt;input class="button" type="submit" value="Import" id="importSubmit"/&gt;
      &lt;/span&gt;
    &lt;/form&gt;
    #end
  {{/html}}
#end
{{/velocity}}</content>
</xwikidoc>

#template("xwikivars.vm")
#skinExtensionHooks
##
## Check if the edit action requires a confirmation.
##
#template('edit_macros.vm')
#getEditConfirmation()
#if ($editConfirmation)
  ## The edit confirmation message may contain block level content that cannot be put into the paragrah generated by
  ## the message box macro, so we print the message ourselves into the message box body.
  #xwikimessageboxstart($editConfirmation.title $NULL)
  $editConfirmation.message
  <p>
  #if ($editConfirmation.confirm)
    ## Allow the user to force the edit.
    #set ($forceEditURL = $doc.getURL('edit', $escapetool.url({'force': 1, 'force_token': $!{services.csrf.getToken()}})))
    <a href="$escapetool.xml($forceEditURL)"
      class="btn btn-warning forceLock">$escapetool.xml($editConfirmation.confirm)</a>
  #end
  </p>
  #xwikimessageboxend()
#else
  <form id="edituser" action="$doc.getURL('save', 'ajax=1')">
    <div class="hidden">
      <input type="hidden" name="form_token" value="$!services.csrf.token" />
    </div>
    $cdoc.getRenderedContent()
  </form>
#end
## Add a link to the complete user profile.
<p>
  $services.localization.render('rightsmanager.edituserprofile')
  <a href="$doc.getURL()">$services.localization.render('rightsmanager.userprofile')</a>.
</p>
